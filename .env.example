# Stellar Network Configuration
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_TESTNET_RPC=https://soroban-testnet.stellar.org
NEXT_PUBLIC_FREIGHTER_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Contract Addresses (Testnet)
NEXT_PUBLIC_PAYMENT_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4
NEXT_PUBLIC_DONATION_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4
NEXT_PUBLIC_CAMPAIGN_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4
NEXT_PUBLIC_RECURRING_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stellarpay

# AI Services
NEXT_PUBLIC_OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_KEY=sk-your-api-key-here

# Wallet Settings
NEXT_PUBLIC_WALLET_TIMEOUT=30000
NEXT_PUBLIC_MIN_BALANCE=1

# Deployment
NEXT_PUBLIC_ENVIRONMENT=development
NEXT_PUBLIC_ANALYTICS_ID=

# Security
NEXT_PUBLIC_RATE_LIMIT_WINDOW=900000
NEXT_PUBLIC_RATE_LIMIT_MAX_REQUESTS=100